{
  "info": {
    "name": "Your Car Your Way - PoC Tchat",
    "_postman_id": "a6a1f3c2-0d8d-4b82-9df0-4d6e7b8c9a10",
    "description": "Collection Postman pour vérifier les endpoints actuellement disponibles de la PoC tchat.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "clientUsername",
      "value": "client1"
    },
    {
      "key": "clientPassword",
      "value": "Client123#"
    },
    {
      "key": "agentUsername",
      "value": "agent1"
    },
    {
      "key": "agentPassword",
      "value": "Agent123#"
    },
    {
      "key": "invalidPassword",
      "value": "wrongpassword"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Client",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{clientUsername}}\",\n  \"password\": \"{{clientPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Réponse contient username et role', function () { const body = pm.response.json(); pm.expect(body).to.have.property('username'); pm.expect(body).to.have.property('role'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Agent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{agentUsername}}\",\n  \"password\": \"{{agentPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Mot de passe invalide",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{clientUsername}}\",\n  \"password\": \"{{invalidPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "Lister les conversations - Client",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/conversations?username={{clientUsername}}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Réponse JSON tableau', function () { const body = pm.response.json(); pm.expect(Array.isArray(body)).to.eql(true); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Lister les conversations - Agent",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/conversations?username={{agentUsername}}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}